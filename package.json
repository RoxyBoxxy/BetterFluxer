{
  "name": "betterfluxer",
  "version": "1.0.0",
  "description": "A BetterDiscord-style plugin runtime for Fluxer",
  "main": "src/index.js",
  "scripts": {
    "start-o": "node src/index.js",
    "start": "cd nw && npx nw .",
    "bridge:app": "cd bridge-nw && npx nw .",
    "test": "node --test",
    "bridge:start": "node bridge-nw/scripts/local-bridge.js",
    "bridge:install": "node bridge-nw/scripts/local-bridge.js --install",
    "bridge:uninstall": "node bridge-nw/scripts/local-bridge.js --uninstall",
    "bridge:startup:install": "node bridge-nw/scripts/local-bridge.js --startup-install",
    "bridge:startup:remove": "node bridge-nw/scripts/local-bridge.js --startup-remove",
    "dist:win": "node scripts/package-win.js",
    "dist:bridge:win": "node scripts/package-bridge-win.js",
    "dist:bridge:msi": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-bridge-msi.ps1",
    "dist:win:onefile": "node scripts/package-win-onefile.js",
    "dist:linux": "node scripts/package-linux.js",
    "dist:bridge:linux": "node scripts/package-bridge-linux.js",
    "dist:win:builder": "node scripts/package-win.js",
    "dist:win:nsis": "node scripts/package-win.js",
    "dist:win:portable": "node scripts/package-win.js",
    "dist:dir": "node scripts/package-linux.js",
    "inject": "node scripts/inject-fluxer.js",
    "uninject": "node scripts/uninject-fluxer.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "nw": "^0.91.0-sdk",
    "nw-builder": "^4.17.5",
    "pkg": "^5.8.1",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "undici": "^7.22.0"
  }
}
